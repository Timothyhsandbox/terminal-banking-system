{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build C++",
            "type": "shell",
            "command": "C:/mingw64/bin/g++.exe",
            "args": [
                "-g",
                "-std=c++17",
                "-Wall",
                "-Wextra",
                "*.cpp",
                "-o",
                "main.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}