{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build All CPP",
            "type": "shell",
            "command": "C:/mingw64/bin/g++.exe",
            "args": [
                "-g",
                "*.cpp",
                "-o",
                "main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}